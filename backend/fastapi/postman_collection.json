                                    "value": "",
                                    "description": "Precio máximo",
                                    "disabled": true
                                },
                                {
                                    "key": "capacityMin",
                                    "value": "",
                                    "description": "Capacidad mínima",
                                    "disabled": true
                                },
                                {
                                    "key": "capacityMax",
