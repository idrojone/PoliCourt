{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: Clean Install (Reconstruir)",
            "type": "shell",
            "command": "./mvnw clean install",
            "windows": {
                "command": ".\\mvnw.cmd clean install"
            },
            "options": {
                "cwd": "${workspaceFolder}/backend/springboot"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$maven-gcc"
        },
        {
            "label": "Maven: Run (Ejecutar sin Debug)",
            "type": "shell",
            "command": "./mvnw spring-boot:run",
            "windows": {
                "command": ".\\mvnw.cmd spring-boot:run"
            },
            "options": {
                "cwd": "${workspaceFolder}/backend/springboot"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Bun: Run (Ejecutar modo desarrollo)",
            "type": "shell",
            "command": "bun dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend/"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Postgres: Iniciar contenedor",
            "type": "shell",
            "command": "docker-compose up -d bd",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}